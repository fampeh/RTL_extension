{
  "manifest_version": 3,
  "name": "Universal Persian RTL Fix",
  "version": "4.3",
  "description": "متن‌های فارسی را در وب‌سایت‌ها با RTL درست و پایدار نمایش می‌دهد",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "default-128.png"
  },
  "icons": {
    "16": "default-16.png",
    "32": "default-32.png",
    "48": "default-48.png",
    "128": "default-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}