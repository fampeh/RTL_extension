{
  "manifest_version": 3,
  "name": "Universal Persian RTL Fix",
  "version": "4.2",
  "description": "متن‌های فارسی را در وب‌سایت‌ها با RTL درست و پایدار نمایش می‌دهد",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon_48.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "48": "icon_48.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
